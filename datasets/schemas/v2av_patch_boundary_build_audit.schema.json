{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "v2av patch boundary build audit",
  "description": "Row contract for v2av_patch_boundary_build_audit.csv. v2av patch boundary builder. No operational label, no training target, no final ground truth; built boundary max meaning READY_FOR_V2AU_OVERLAY.",
  "type": "object",
  "required": [
    "decision_id",
    "patch_id",
    "gate_name",
    "gate_passed",
    "gate_status",
    "required_condition",
    "observed_value",
    "severity",
    "blocking_reason",
    "recommended_action"
  ],
  "additionalProperties": false,
  "properties": {
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "patch_id": {
      "type": "string"
    },
    "gate_name": {
      "type": "string",
      "enum": [
        "PATCH_BOUNDARY_GATE_01_PATCH_ID_EXISTS",
        "PATCH_BOUNDARY_GATE_02_SOURCE_METADATA_FOUND",
        "PATCH_BOUNDARY_GATE_03_CRS_EXISTS",
        "PATCH_BOUNDARY_GATE_04_CRS_ACCEPTED",
        "PATCH_BOUNDARY_GATE_05_BOUNDARY_METHOD_ALLOWED",
        "PATCH_BOUNDARY_GATE_06_GEOMETRY_VALID",
        "PATCH_BOUNDARY_GATE_07_AREA_COMPUTABLE",
        "PATCH_BOUNDARY_GATE_08_NOT_BUILT_FROM_UNVERIFIED_DEFAULT",
        "PATCH_BOUNDARY_GATE_09_NO_EVENT_LABEL_CREATED",
        "PATCH_BOUNDARY_GATE_10_READY_FOR_V2AU_OVERLAY"
      ]
    },
    "gate_passed": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "gate_status": {
      "type": "string"
    },
    "required_condition": {
      "type": "string"
    },
    "observed_value": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "BLOCKING",
        "GUARDRAIL",
        "INFO"
      ]
    },
    "blocking_reason": {
      "type": "string"
    },
    "recommended_action": {
      "type": "string"
    }
  },
  "x_id_field": "decision_id",
  "x_csv_file": "datasets/v2av_patch_boundary_build_audit.csv"
}
