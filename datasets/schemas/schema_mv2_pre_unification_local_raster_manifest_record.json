{
  "schema_id": "revp_mv2_pre_unification_local_raster_manifest_record",
  "description": "Lightweight pre-unification contract; no supervised training or public raster output.",
  "required_fields": [
    "patch_id",
    "asset_id",
    "product_id",
    "is_public",
    "crop_status",
    "scl_qa_status"
  ],
  "fields": {
    "patch_id": "str",
    "asset_id": "str",
    "product_id": "str",
    "local_only_path": "str|null",
    "sha256": "str|null",
    "size_bytes": "int|null",
    "raster_type": "GEOTIFF|COG|OTHER|UNKNOWN",
    "is_public": "false",
    "crop_status": "NOT_AUTHORIZED|AUTHORIZED|DONE|INVALID",
    "scl_qa_status": "NOT_RUN|READY|DONE|FAILED",
    "blocked_reason": "str|null"
  },
  "forbidden_states": [
    "DAY10_UNLOCKED",
    "NEGATIVE_READY",
    "SANDBOX_READY",
    "SILVER_READY",
    "SUPERVISED_READY",
    "TRAINING_READY"
  ],
  "allowed_execution_states": [
    "BLOCKED_NO_CONFIG",
    "BLOCKED_NO_NATIVE_RASTER",
    "BLOCKED_NO_PRODUCT_ID",
    "BLOCKED_NO_SENSOR_LINEAGE",
    "BLOCKED_NO_TEMPORAL_WINDOW",
    "CROP_AUTHORIZATION_READY",
    "LOCAL_ONLY_RASTER_READY",
    "METADATA_CONFIRMED",
    "METADATA_ONLY_READY",
    "SCL_QA_READY"
  ]
}
