    "urban_context": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "permanent_water_risk": {
      "type": "string"
    },
    "occlusion_risk": {
      "type": "string"
    },
    "evidence_count": {
      "type": "string"
    },
    "strong_evidence_count": {
      "type": "string"
    },
    "weak_evidence_count": {
      "type": "string"
    },
    "conflict_count": {
      "type": "string"
