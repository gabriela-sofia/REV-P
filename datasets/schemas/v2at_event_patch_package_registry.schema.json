      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "has_only_contextual_sources": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "has_geometry": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "has_patch_overlay": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
