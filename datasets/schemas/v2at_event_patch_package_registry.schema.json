      "type": "string",
      "enum": [
        "C0",
        "C1",
        "C2",
        "C3",
        "C4_CANDIDATE"
      ]
    },
    "promotion_decision": {
      "type": "string"
    },
    "blocking_reason": {
      "type": "string"
    },
    "allowed_use": {
      "type": "string",
      "enum": [
