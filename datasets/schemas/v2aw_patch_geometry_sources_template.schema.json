{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "v2aw patch geometry sources template",
  "description": "Row contract for v2aw_patch_geometry_sources_template.csv. v2aw geometry intake. No operational label, no training target, no final ground truth; max meaning READY_FOR_V2AV/READY_FOR_V2AU.",
  "type": "object",
  "required": [
    "geometry_source_id",
    "linked_patch_id",
    "region",
    "city",
    "priority_rank",
    "source_type",
    "geometry_value",
    "geometry_path",
    "crs",
    "provenance_type",
    "provenance_note",
    "digitized_by",
    "digitized_at",
    "source_document",
    "source_document_page",
    "source_confidence",
    "license_status",
    "review_status",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "geometry_source_id": {
      "type": "string",
      "minLength": 1
    },
    "linked_patch_id": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "priority_rank": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "bbox",
        "wkt",
        "geojson_inline",
        "geojson_file",
        "missing"
      ]
    },
    "geometry_value": {
      "type": "string"
    },
    "geometry_path": {
      "type": "string"
    },
    "crs": {
      "type": "string"
    },
    "provenance_type": {
      "type": "string",
      "enum": [
        "sentinel_footprint",
        "patch_generation_metadata",
        "manual_digitization",
        "gis_export",
        "official_vector",
        "unknown"
      ]
    },
    "provenance_note": {
      "type": "string"
    },
    "digitized_by": {
      "type": "string"
    },
    "digitized_at": {
      "type": "string"
    },
    "source_document": {
      "type": "string"
    },
    "source_document_page": {
      "type": "string"
    },
    "source_confidence": {
      "type": "string"
    },
    "license_status": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "not_started",
        "provided_unreviewed",
        "format_validated",
        "needs_fix",
        "approved_for_v2av",
        "rejected"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "x_id_field": "geometry_source_id",
  "x_csv_file": "datasets/v2aw_patch_geometry_sources_template.csv"
}
