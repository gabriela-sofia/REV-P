{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "v2at operational label blocklist",
  "description": "Row contract for v2at_operational_label_blocklist.csv. Generated/validated by v2at engine. No operational label, no training target.",
  "type": "object",
  "required": [
    "block_id",
    "package_id",
    "event_id",
    "patch_id",
    "reason",
    "source_of_block",
    "severity",
    "can_be_revisited",
    "required_evidence_to_unblock"
  ],
  "additionalProperties": false,
  "properties": {
    "block_id": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "patch_id": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "source_of_block": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "BLOCKING",
        "POLICY"
      ]
    },
    "can_be_revisited": {
      "type": "string",
      "enum": [
        "true",
        "false"
      ]
    },
    "required_evidence_to_unblock": {
      "type": "string"
    }
  },
  "x_id_field": "block_id",
  "x_csv_file": "datasets/v2at_operational_label_blocklist.csv"
}
